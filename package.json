{
  "name": "ai-services",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "build": "npm run clean && tsc && mkdir -p dist/routes/oauth && cp -r src/routes/oauth/public dist/routes/oauth/",
    "build:watch": "tsc --watch --preserveWatchOutput",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "node dist/index.js",
    "prod": "npm run build && npm run start"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.15.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sequelize": "^6.37.8",
    "sequelize-cli": "^6.6.5",
    "zod": "^4.3.6"
  }
}
