{
  "name": "ai-services",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "build": "npm run clean && tsc",
    "build:watch": "tsc --watch --preserveWatchOutput",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "node dist/index.js",
    "prod": "npm run build && npm run start"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "imports": {
    "#config/*": "./dist/config/*.js",
    "#utils/*": "./dist/utils/*.js",
    "#routes/*": "./dist/routes/*.js",
    "#middleware/*": "./dist/middleware/*.js",
    "#types/*": "./dist/types/*.js"
  }
}
